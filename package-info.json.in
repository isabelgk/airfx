{
    "author": "Isabel Kaspriskie",
    "description": "Airwindows plugins as Max objects",
    "homepatcher": "",
    "max_version_min": "8.0",
    "max_version_max": "none",
    "name": "airfx",
    "os": {
        "macintosh": {
            "platform": [
                "x64",
                "arm64"
            ],
            "min_version": "none"
        },
        "windows": {
            "platform": [
                "x64"
            ],
            "min_version": "none"
        }
    },
    "package_extra": {
        "reverse_domain": "com.isabelgk"
    },
    "tags": [
        "effects",
        "audio"
    ],
    "version": "@PACKAGE_VERSION@",
    "website": "http://www.github.com/isabelgk/airfx"
}
