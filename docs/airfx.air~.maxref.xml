<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<?xml-stylesheet href="./c74ref.xsl" type="text/xsl"?>

<c74object name="airfx.air~" module="MSP" category="brightness">

	<digest>
		Air is a different bright EQ from any other. Requires 44.1K.
	</digest>

	<description>
		Air is a different bright EQ from any other. Requires 44.1K.
	</description>

	<discussion>
		See Air2 for more on this. Air is the same, but simpler, and restricted to one sample rate so that if you're at a higher sample rate, the effects will shift up in frequency, possibly making them inaudible.
	</discussion>

	<metadatalist>
		<metadata name="author">Isabel Kaspriskie</metadata>
		<metadata name="tag">Airwindows</metadata>
		<metadata name="tag">brightness</metadata>
	</metadatalist>

	<inletlist>
		<inlet id="0" type="signal">
			<digest>(signal) Input L</digest>
		</inlet>
		<inlet id="1" type="signal">
			<digest>(signal) Input R</digest>
		</inlet>
	</inletlist>

	<outletlist>
		<outlet id="0" type="signal">
			<digest>(signal) Output L</digest>
		</outlet>
		<outlet id="1" type="signal">
			<digest>(signal) Output R</digest>
		</outlet>
		<outlet id="2" type="anything">
			<digest>Dump outlet</digest>
		</outlet>
	</outletlist>

	<methodlist>
		<method name="about">
			<digest>Get the original Airwindows "about" text for this object</digest>
			<description>
				Prints the original Airwindows description for this plugin out the
				dump outlet.
			</description>
		</method>
	</methodlist>

	<attributelist>
		<attribute name="22k_tap" get="1" set="1" type="float64" size="1">
			<digest>22K tap</digest>
			<description>
				Range 0.0-1.0. Default 0.
			</description>
		</attribute>
		<attribute name="15k_tap" get="1" set="1" type="float64" size="1">
			<digest>15K tap</digest>
			<description>
				Range 0.0-1.0. Default 0.
			</description>
		</attribute>
		<attribute name="11k_tap" get="1" set="1" type="float64" size="1">
			<digest>11K tap</digest>
			<description>
				Range 0.0-1.0. Default 0.5.
			</description>
		</attribute>
		<attribute name="filters_q" get="1" set="1" type="float64" size="1">
			<digest>filters Q</digest>
			<description>
				Range 0.0-1.0. Default 0.
			</description>
		</attribute>
		<attribute name="output_level" get="1" set="1" type="float64" size="1">
			<digest>Output Level</digest>
			<description>
				Range 0.0-1.0. Default 1.
			</description>
		</attribute>
		<attribute name="dry/wet" get="1" set="1" type="float64" size="1">
			<digest>Dry/Wet</digest>
			<description>
				Range 0.0-1.0. Default 1.
			</description>
		</attribute>
	</attributelist>

</c74object>
