<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<?xml-stylesheet href="./c74ref.xsl" type="text/xsl"?>

<c74object name="airfx.bite~" module="MSP" category="lo-fi">

	<digest>
		Bite is an unusual edge-maker.
	</digest>

	<description>
		Bite is an unusual edge-maker.
	</description>

	<discussion>
		Bite puts on a sort of midrange edge. At high sample rates it’ll be more of a trebly edge. It’s no specific frequency, so much as it’s just a harshening factor: you can also use it inversely, to take out midrange edge. It runs a couple samples of latency: on VST that works as a couple samples of delay. Again: an experiment, a science project.
	</discussion>

	<metadatalist>
		<metadata name="author">Isabel Kaspriskie</metadata>
		<metadata name="tag">Airwindows</metadata>
		<metadata name="tag">lo-fi</metadata>
	</metadatalist>

	<inletlist>
		<inlet id="0" type="signal">
			<digest>(signal) Input L</digest>
		</inlet>
		<inlet id="1" type="signal">
			<digest>(signal) Input R</digest>
		</inlet>
	</inletlist>

	<outletlist>
		<outlet id="0" type="signal">
			<digest>(signal) Output L</digest>
		</outlet>
		<outlet id="1" type="signal">
			<digest>(signal) Output R</digest>
		</outlet>
		<outlet id="2" type="anything">
			<digest>Dump outlet</digest>
		</outlet>
	</outletlist>

	<methodlist>
		<method name="about">
			<digest>Get the original Airwindows "about" text for this object</digest>
			<description>
				Prints the original Airwindows description for this plugin out the
				dump outlet.
			</description>
		</method>
	</methodlist>

	<attributelist>
		<attribute name="bite" get="1" set="1" type="float64" size="1">
			<digest>Bite</digest>
			<description>
				Range 0.0-1.0. Default 0.5.
			</description>
		</attribute>
		<attribute name="output_level" get="1" set="1" type="float64" size="1">
			<digest>Output Level</digest>
			<description>
				Range 0.0-1.0. Default 1.
			</description>
		</attribute>
	</attributelist>

</c74object>
