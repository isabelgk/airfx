<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<?xml-stylesheet href="./c74ref.xsl" type="text/xsl"?>

<c74object name="airfx.cider~" module="MSP" category="tone-color">

	<digest>
		Cider is a re-release of another old Character plugin.
	</digest>

	<description>
		Cider is a re-release of another old Character plugin.
	</description>

	<discussion>
		Cider is another Character plugin. Works like the last few, sounds kinda like an MCI console? This plugin was posted on a week full of troubles, so there's very little instruction about it. It's a tone coloring plugin, and you can find a more current version of this sound in BussColors4 on the Dark setting.
	</discussion>

	<metadatalist>
		<metadata name="author">Isabel Kaspriskie</metadata>
		<metadata name="tag">Airwindows</metadata>
		<metadata name="tag">tone-color</metadata>
	</metadatalist>

	<inletlist>
		<inlet id="0" type="signal">
			<digest>(signal) Input L</digest>
		</inlet>
		<inlet id="1" type="signal">
			<digest>(signal) Input R</digest>
		</inlet>
	</inletlist>

	<outletlist>
		<outlet id="0" type="signal">
			<digest>(signal) Output L</digest>
		</outlet>
		<outlet id="1" type="signal">
			<digest>(signal) Output R</digest>
		</outlet>
		<outlet id="2" type="anything">
			<digest>Dump outlet</digest>
		</outlet>
	</outletlist>

	<methodlist>
		<method name="about">
			<digest>Get the original Airwindows "about" text for this object</digest>
			<description>
				Prints the original Airwindows description for this plugin out the
				dump outlet.
			</description>
		</method>
	</methodlist>

	<attributelist>
		<attribute name="hardns" get="1" set="1" type="float64" size="1">
			<digest>Hardns</digest>
			<description>
				Range 0.0-1.0. Default 0.7.
			</description>
		</attribute>
		<attribute name="persnlty" get="1" set="1" type="float64" size="1">
			<digest>Persnlty</digest>
			<description>
				Range 0.0-1.0. Default 0.3333333.
			</description>
		</attribute>
		<attribute name="drive" get="1" set="1" type="float64" size="1">
			<digest>Drive</digest>
			<description>
				Range 0.0-1.0. Default 0.3333333.
			</description>
		</attribute>
		<attribute name="output" get="1" set="1" type="float64" size="1">
			<digest>Output</digest>
			<description>
				Range 0.0-1.0. Default 1.
			</description>
		</attribute>
	</attributelist>

</c74object>
