<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<?xml-stylesheet href="./c74ref.xsl" type="text/xsl"?>

<c74object name="airfx.console8litechannel~" module="MSP" category="consoles">

	<digest>
		Console8LiteChannel is simplified Console8, working with just a single mix buss.
	</digest>

	<description>
		Console8LiteChannel is simplified Console8, working with just a single mix buss.
	</description>

	<discussion>
		
	</discussion>

	<metadatalist>
		<metadata name="author">Isabel Kaspriskie</metadata>
		<metadata name="tag">Airwindows</metadata>
		<metadata name="tag">consoles</metadata>
	</metadatalist>

	<inletlist>
		<inlet id="0" type="signal">
			<digest>(signal) Input L</digest>
		</inlet>
		<inlet id="1" type="signal">
			<digest>(signal) Input R</digest>
		</inlet>
	</inletlist>

	<outletlist>
		<outlet id="0" type="signal">
			<digest>(signal) Output L</digest>
		</outlet>
		<outlet id="1" type="signal">
			<digest>(signal) Output R</digest>
		</outlet>
		<outlet id="2" type="anything">
			<digest>Dump outlet</digest>
		</outlet>
	</outletlist>

	<methodlist>
		<method name="about">
			<digest>Get the original Airwindows "about" text for this object</digest>
			<description>
				Prints the original Airwindows description for this plugin out the
				dump outlet.
			</description>
		</method>
	</methodlist>

	<attributelist>
		<attribute name="fader" get="1" set="1" type="float64" size="1">
			<digest>Fader</digest>
			<description>
				Range 0.0-1.0. Default 0.5.
			</description>
		</attribute>
	</attributelist>

</c74object>
